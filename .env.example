# Database
DATABASE_URL="postgresql://user:password@localhost:5432/opencadence?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Google OAuth (Better Auth)
# Get these from: https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: {YOUR_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Better Auth Secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=""

# Strava OAuth
# Get these from: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_WEBHOOK_VERIFY_TOKEN=""

# Encryption key for Garmin credentials (32 bytes hex-encoded for AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
