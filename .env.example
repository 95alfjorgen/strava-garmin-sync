# Strava API credentials
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Strava OAuth tokens
# Generate with: node scripts/generate-strava-token.js
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
STRAVA_TOKEN_EXPIRES_AT=

# Garmin token (base64 encoded)
# Generate with: node scripts/generate-garmin-token.js
GARMIN_TOKEN=

# Sync settings (optional)
SYNC_DAYS=30
DATA_DIR=./data
