generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  SKIPPED
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  emailVerified         Boolean   @default(false)
  name                  String?
  image                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Strava Connection (optional - now a service, not login)
  stravaConnected       Boolean   @default(false)
  stravaAthleteId       Int?      @unique
  stravaAccessToken     String?
  stravaRefreshToken    String?
  stravaTokenExpiresAt  DateTime?
  stravaAthleteName     String?
  stravaAthleteImage    String?

  // Garmin Connection (encrypted)
  garminConnected       Boolean   @default(false)
  garminEmail           String?
  garminPasswordEnc     String?
  garminSessionData     String?

  // Settings
  liveSyncEnabled       Boolean   @default(true)

  // Relations
  sessions              Session[]
  accounts              Account[]
  syncRecords           SyncRecord[]
}

model Session {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique
  expiresAt     DateTime
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SyncRecord {
  id               String     @id @default(cuid())
  userId           String
  stravaActivityId BigInt     @unique
  garminActivityId String?
  status           SyncStatus @default(PENDING)
  activityType     String?
  activityName     String?
  deviceName       String?
  syncedAt         DateTime?
  errorMessage     String?
  retryCount       Int        @default(0)

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model WebhookSubscription {
  id             String   @id @default(cuid())
  subscriptionId Int      @unique
  verifyToken    String
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum GarminQueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model GarminConnectionQueue {
  id              String             @id @default(cuid())
  userId          String             @unique // One pending request per user
  garminEmail     String
  garminPasswordEnc String           // Encrypted password
  status          GarminQueueStatus  @default(PENDING)
  errorMessage    String?
  retryCount      Int                @default(0)
  nextRetryAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([nextRetryAt])
}
